# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Neon + Prisma) ─────────────────────────────────────────────────
DATABASE_URL=

# ─── Clerk (Backend) ──────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── Super Admin Control ──────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_ALLOWED_DOMAINS=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email ────────────────────────────────────────────────────────────────────
# choose provider: resend | smtp
EMAIL_PROVIDER=resend
RESEND_API_KEY=

# OR SMTP fallback
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── App Config ───────────────────────────────────────────────────────────────
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ─── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
