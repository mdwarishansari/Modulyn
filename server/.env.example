# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (NeonDB) ─────────────────────────────────────────────────────────
# Get your connection string from: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/modulyn?sslmode=require"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 64
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Access token expiry (e.g.: 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry (e.g.: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
